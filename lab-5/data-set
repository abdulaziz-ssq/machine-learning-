    "def haversine_km(lat1, lon1, lat2, lon2):\n",
    "    \"\"\"Vectorized Haversine distance in kilometers.\"\"\"\n",
    "    R = 6371.0\n",
    "    lat1 = np.radians(lat1); lon1 = np.radians(lon1)\n",
    "    lat2 = np.radians(lat2); lon2 = np.radians(lon2)\n",
    "    dlat = lat2 - lat1\n",
    "    dlon = lon2 - lon1\n",
